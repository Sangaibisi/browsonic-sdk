{
  "name": "@browsonic/nextjs",
  "version": "1.2.0",
  "description": "Next.js adapter for @browsonic/sdk — App Router error pages, route-handler capture, instrumentation entry. Re-exports @browsonic/react. Apache-2.0.",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./instrumentation": {
      "types": "./dist/types/instrumentation/index.d.ts",
      "import": "./dist/esm/instrumentation/index.js",
      "require": "./dist/cjs/instrumentation/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run stamp-version && npm run build:esm && npm run build:cjs && npm run build:types",
    "stamp-version": "node scripts/stamp-version.mjs",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:types": "tsc -p tsconfig.types.json",
    "dev": "tsc -p tsconfig.esm.json --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rimraf dist coverage",
    "semantic-release": "semantic-release"
  },
  "keywords": [
    "next",
    "nextjs",
    "next.js",
    "browsonic",
    "browsonic-nextjs",
    "javascript-error-monitoring",
    "browser-error-tracking",
    "exception-tracking",
    "rum",
    "telemetry",
    "nextjs-adapter"
  ],
  "author": "Emrullah Yıldırım <emrullahyildirim@windowslive.com>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Sangaibisi/browsonic-sdk/tree/main/packages/nextjs#readme",
  "bugs": {
    "url": "https://github.com/Sangaibisi/browsonic-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sangaibisi/browsonic-sdk.git",
    "directory": "packages/nextjs"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "@browsonic/react": "^0.1.0 || ^1.0.0",
    "@browsonic/sdk": ">=2.2.1",
    "next": ">=13.4.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@browsonic/react": "*",
    "@browsonic/sdk": "*",
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/npm": "^13.0.0",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "happy-dom": "^20.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^6.1.3",
    "semantic-release": "^24.2.7",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.59.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
