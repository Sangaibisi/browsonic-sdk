{
  "name": "@browsonic/sdk",
  "version": "2.2.1",
  "description": "Privacy-first browser RUM and error tracking SDK. Lightweight (~15-22 KB gzipped), framework-agnostic, no PII by default.",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./core": {
      "types": "./dist/types/core.d.ts",
      "import": "./dist/esm/core.js",
      "require": "./dist/cjs/core.js"
    },
    "./widget": {
      "types": "./dist/types/widget-entry.d.ts",
      "import": "./dist/esm/widget-entry.js",
      "require": "./dist/cjs/widget-entry.js"
    },
    "./umd": {
      "browser": "./dist/umd/browsonic.min.js"
    },
    "./umd/unminified": {
      "browser": "./dist/umd/browsonic.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && npm run build:types && npm run build:umd",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:types": "tsc -p tsconfig.types.json",
    "build:umd": "node scripts/build-umd.mjs",
    "dev": "tsc -p tsconfig.esm.json --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build:e2e": "node scripts/build-e2e-bundle.mjs",
    "test:e2e": "npm run build:e2e && playwright test",
    "test:e2e:ui": "npm run build:e2e && playwright test --ui",
    "bench": "vitest bench --run --outputJson=bench-results.json",
    "bench:check": "node scripts/check-bench-regression.mjs bench-baseline.json 0.10",
    "size": "npm run build && size-limit",
    "size:why": "size-limit --why",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rimraf dist bench-results.json e2e-results playwright-report coverage",
    "perf:all": "npm run build && npm run bench && npm run size && npm run test:e2e",
    "prepare": "husky || true",
    "semantic-release": "semantic-release"
  },
  "keywords": [
    "rum",
    "real-user-monitoring",
    "error-tracking",
    "javascript-error-monitoring",
    "browser-error-tracking",
    "client-side-error-tracking",
    "exception-tracking",
    "crash-reporting",
    "observability",
    "monitoring",
    "telemetry",
    "logging",
    "frontend",
    "browser",
    "sdk",
    "privacy-first",
    "apache-2"
  ],
  "author": "Emrullah Yıldırım <emrullahyildirim@windowslive.com>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Sangaibisi/browsonic-sdk#readme",
  "bugs": {
    "url": "https://github.com/Sangaibisi/browsonic-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sangaibisi/browsonic-sdk.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.45.0",
    "@size-limit/preset-small-lib": "^11.1.0",
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^3.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "rimraf": "^6.1.3",
    "semantic-release": "^24.2.7",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/npm": "^13.0.0",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/release-notes-generator": "^14.0.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "size-limit": "^11.1.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.59.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.{ts,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}
