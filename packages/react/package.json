{
  "name": "@browsonic/react",
  "version": "0.0.0-development",
  "description": "React adapter for @browsonic/sdk — error boundary, hooks, HOC, React Router instrumentation. Apache-2.0.",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && npm run build:types",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:types": "tsc -p tsconfig.types.json",
    "dev": "tsc -p tsconfig.esm.json --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rimraf dist coverage",
    "prepare": "husky || true",
    "semantic-release": "semantic-release"
  },
  "keywords": [
    "react",
    "react-error-boundary",
    "browsonic",
    "browsonic-react",
    "javascript-error-monitoring",
    "browser-error-tracking",
    "exception-tracking",
    "rum",
    "telemetry",
    "react-adapter"
  ],
  "author": "Emrullah Yıldırım <emrullahyildirim@windowslive.com>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Sangaibisi/browsonic-react#readme",
  "bugs": {
    "url": "https://github.com/Sangaibisi/browsonic-react/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sangaibisi/browsonic-react.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "@browsonic/sdk": "^2.2.1",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@browsonic/sdk": "^2.2.1",
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/release-notes-generator": "^14.0.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.59.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}
