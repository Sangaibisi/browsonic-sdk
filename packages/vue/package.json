{
  "name": "@browsonic/vue",
  "version": "1.3.0",
  "description": "Vue 3 adapter for @browsonic/sdk — error boundary, composables, app plugin with errorHandler chaining. Apache-2.0.",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run stamp-version && npm run build:esm && npm run build:cjs && npm run build:types",
    "stamp-version": "node scripts/stamp-version.mjs",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:types": "tsc -p tsconfig.types.json",
    "dev": "tsc -p tsconfig.esm.json --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rimraf dist coverage",
    "semantic-release": "semantic-release"
  },
  "keywords": [
    "vue",
    "vue3",
    "browsonic",
    "browsonic-vue",
    "javascript-error-monitoring",
    "browser-error-tracking",
    "exception-tracking",
    "rum",
    "telemetry",
    "vue-adapter"
  ],
  "author": "Emrullah Yıldırım <emrullahyildirim@windowslive.com>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Sangaibisi/browsonic-sdk/tree/main/packages/vue#readme",
  "bugs": {
    "url": "https://github.com/Sangaibisi/browsonic-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sangaibisi/browsonic-sdk.git",
    "directory": "packages/vue"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "@browsonic/sdk": ">=2.2.1",
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@browsonic/sdk": "*",
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/npm": "^13.0.0",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/vue": "^8.1.0",
    "@vitest/coverage-v8": "^3.0.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^10.4.0",
    "happy-dom": "^20.9.0",
    "rimraf": "^6.1.3",
    "semantic-release": "^24.2.7",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^3.0.0",
    "vue": "^3.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}
