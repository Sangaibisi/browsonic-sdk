{
  "name": "browsonic-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Browsonic monorepo — privacy-first browser error tracking SDK and framework adapters.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Sangaibisi/browsonic-sdk#readme",
  "bugs": {
    "url": "https://github.com/Sangaibisi/browsonic-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sangaibisi/browsonic-sdk.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @browsonic/sdk && npm run build -w @browsonic/react && npm run build -w @browsonic/vue -w @browsonic/svelte -w @browsonic/angular -w @browsonic/astro && npm run build -w @browsonic/nextjs -w @browsonic/remix",
    "_build:prereq": "npm run build -w @browsonic/sdk && npm run build -w @browsonic/react",
    "test": "npm run test --workspaces --if-present",
    "test:run": "npm run test:run --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "lint": "npm run _build:prereq && npm run lint --workspaces --if-present",
    "lint:fix": "npm run _build:prereq && npm run lint:fix --workspaces --if-present",
    "typecheck": "npm run _build:prereq && npm run typecheck --workspaces --if-present",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx,mjs}\" \"packages/*/*.{json,md}\" \"docs/**/*.md\" \"*.md\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx,mjs}\" \"packages/*/*.{json,md}\" \"docs/**/*.md\" \"*.md\"",
    "size": "npm run size --workspaces --if-present",
    "bench": "npm run bench --workspaces --if-present",
    "bench:check": "npm run bench:check --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present && rimraf node_modules",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "rimraf": "^6.1.3"
  },
  "overrides": {
    "picomatch": "^4.0.4",
    "semantic-release": {
      "@semantic-release/npm": "^13.0.0",
      "npm": "^11.0.0"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,mjs,json,md,yml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}
